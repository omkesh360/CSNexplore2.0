Options -Indexes -MultiViews
ServerSignature Off

# ── PHP Settings ─────────────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  display_errors     Off
    php_flag  log_errors         On
    php_value error_log          logs/php_errors.log
    php_value upload_max_filesize 10M
    php_value post_max_size       12M
    php_value max_execution_time  60
    php_value memory_limit        256M
</IfModule>

# ── Security Headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "SAMEORIGIN"
    Header always set X-XSS-Protection          "1; mode=block"
    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
    Header always set Permissions-Policy        "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    # No-cache for HTML pages so auth state is always fresh
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    # Remove server info
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ── Block sensitive files ─────────────────────────────────────────────────────
<FilesMatch "\.(db|sqlite|sql|log|json|lock|env|git|md|txt)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Allow robots.txt and sitemap.xml
<Files "robots.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "sitemap.xml">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>

# Block direct access to php/ directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^php/(?!api/).*$ - [F,L]
</IfModule>

# ── Gzip Compression ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>

# ── Browser Caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg         "access plus 1 year"
    ExpiresByType image/jpeg        "access plus 1 year"
    ExpiresByType image/png         "access plus 1 year"
    ExpiresByType image/gif         "access plus 1 year"
    ExpiresByType image/webp        "access plus 1 year"
    ExpiresByType image/svg+xml     "access plus 1 year"
    ExpiresByType image/x-icon      "access plus 1 year"
    ExpiresByType font/woff         "access plus 1 year"
    ExpiresByType font/woff2        "access plus 1 year"
    ExpiresByType text/css          "access plus 1 month"
    ExpiresByType text/javascript   "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html         "access plus 0 seconds"
    ExpiresByType application/json  "access plus 0 seconds"
</IfModule>

# ── URL Rewriting ─────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Pass Authorization header (required for JWT)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Remove RewriteBase if present or set to current dir
    # RewriteBase /

    # ── 1. Remove trailing slashes (except for real directories) ───────────
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [R=301,L]

    # ── 2. Handle Blog pages: /blogs/1-my-slug → blog-detail.php?id=1 ────────
    # Extract blog ID from URL and route to dynamic blog-detail.php
    # This must come BEFORE the "Serve real static files" rule
    RewriteRule ^blogs/([0-9]+)-[a-z0-9-]+(?:\.html)?$ blog-detail.php?id=$1 [L,QSA]

    # ── 3. Handle Listing detail: /listing-detail/cars-5-slug ───────────────
    # If a match is found, rewrite to the .html file inside listing-detail/
    RewriteRule ^listing-detail/([a-z0-9-]+)$ listing-detail/$1.html [L]

    # ── 4. Serve real static files (images, CSS, JS, etc.) ──────────────────
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ── 5. Serve real directories (like /admin) ─────────────────────────────
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── 6. Extensionless PHP files (/about → about.php) ──────────────────────
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/.]+)$ $1.php [L]

    # ── 7. Home & Listing fallback ──────────────────────────────────────────
    RewriteRule ^$                    index.php       [L]
    RewriteRule ^index/?$             index.php       [L]
    RewriteRule ^listing/([a-z-]+)/?$ listing.php?type=$1 [QSA,L]
    RewriteRule ^listing/?$           listing.php     [QSA,L]
    RewriteRule ^blog-detail/?$       blog-detail.php [QSA,L]

    # Dynamic sitemap (note: updated path to match your structure)
    RewriteRule ^sitemap\.xml$ php/api/generate_sitemap.php [L]
</IfModule>

# ── Custom Error Pages ────────────────────────────────────────────────────────
ErrorDocument 404 /index.php
ErrorDocument 403 /index.php
ErrorDocument 500 /index.php
