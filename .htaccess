Options -Indexes -MultiViews
ServerSignature Off

# ── PHP Settings ─────────────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  display_errors     Off
    php_flag  log_errors         On
    php_value error_log          logs/php_errors.log
    php_value upload_max_filesize 10M
    php_value post_max_size       12M
    php_value max_execution_time  60
    php_value memory_limit        256M
</IfModule>

# ── Security Headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "SAMEORIGIN"
    Header always set X-XSS-Protection          "1; mode=block"
    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
    Header always set Permissions-Policy        "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    # No-cache for HTML pages so auth state is always fresh
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    # Remove server info
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ── Block sensitive files ─────────────────────────────────────────────────────
<FilesMatch "\.(db|sqlite|sql|log|json|lock|env|git|md|txt)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Allow robots.txt and sitemap.xml
<Files "robots.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "sitemap.xml">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>

# Block direct access to php/ directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^php/(?!api/).*$ - [F,L]
</IfModule>

# ── Gzip Compression ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>

# ── Browser Caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg         "access plus 1 year"
    ExpiresByType image/jpeg        "access plus 1 year"
    ExpiresByType image/png         "access plus 1 year"
    ExpiresByType image/gif         "access plus 1 year"
    ExpiresByType image/webp        "access plus 1 year"
    ExpiresByType image/svg+xml     "access plus 1 year"
    ExpiresByType image/x-icon      "access plus 1 year"
    ExpiresByType font/woff         "access plus 1 year"
    ExpiresByType font/woff2        "access plus 1 year"
    ExpiresByType text/css          "access plus 1 month"
    ExpiresByType text/javascript   "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html         "access plus 0 seconds"
    ExpiresByType application/json  "access plus 0 seconds"
</IfModule>

# ── URL Rewriting ─────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Prevent Apache from auto-redirecting /blogs → /blogs/ before our rules fire
    DirectorySlash Off

    # Pass Authorization header to PHP (required for JWT auth)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Force HTTPS (uncomment on live server with SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove trailing slash (unless it's the root)
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [R=301,L]




    # ── Explicit clean URL mappings for every PHP page ───────────────────────
    RewriteRule ^$                    index.php       [L]
    RewriteRule ^index$               index.php       [L]
    RewriteRule ^about$               about.php       [L]
    RewriteRule ^contact$             contact.php     [L]
    RewriteRule ^blogs$               blogs.php       [L]
    RewriteRule ^listing/([a-z-]+)$   listing.php?type=$1 [QSA,L]
    RewriteRule ^listing$             listing.php     [QSA,L]
    RewriteRule ^login$               login.php       [L]
    RewriteRule ^register$            register.php    [L]
    RewriteRule ^privacy$             privacy.php     [L]
    RewriteRule ^terms$               terms.php       [L]
    RewriteRule ^my-booking$          my-booking.php  [L]
    RewriteRule ^bus$                 bus.php         [L]
    RewriteRule ^blog-detail$         blog-detail.php [QSA,L]

    # ── Serve real static files (images, CSS, JS, fonts, etc.) ──────────────
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ── Static HTML pages: /blogs/1-my-slug → blogs/1-my-slug.html ──────────
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
    RewriteRule ^ %{REQUEST_URI}.html [L]

    # ── Serve real directories (needed for /admin etc.) ─────────────────────
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Dynamic sitemap
    RewriteRule ^sitemap\.xml$ php/api/generate_sitemap.php [L]
</IfModule>

# ── Custom Error Pages ────────────────────────────────────────────────────────
ErrorDocument 404 /index.php
ErrorDocument 403 /index.php
ErrorDocument 500 /index.php
